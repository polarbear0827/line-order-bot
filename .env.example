# ==========================================
# 複製此檔案為 .env 並填入實際值
# ==========================================

# LINE Bot 設定（從 LINE Developers Console 取得）
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_GROUP_ID=your_line_group_id_here

# OpenRouter API（用於 OCR 菜單辨識）
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ngrok Authtoken (從 ngrok 後台 Your Authtoken 取得)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# 後台管理員金鑰
ADMIN_ACCESS_KEY=your_admin_password_here

# Flask 安全金鑰（隨意填一串英數字）
SECRET_KEY=change_this_to_a_random_string_123456

# 推播設定
DAILY_PUSH_HOUR=20
DAILY_PUSH_MINUTE=30
